generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ExerciseCard {
  id           Int      @id @default(autoincrement())
  character    String
  trend        String
  phrase       String
  voiceType    String
  voiceEmotion String
  image        String
  color        String
  difficulty   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Profile {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  child
  parent
}
